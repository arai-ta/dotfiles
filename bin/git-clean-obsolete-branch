#!/bin/bash
#
# @(#) Tiny script that cleans up outdated local branches.
#

set -e
set -u
set -x

if [ x"${1:-}" = "x-f" ]
then
    delete_cmd="-D"
else
    delete_cmd="-d"
fi

git diff --exit-code

BRANCH="`git symbolic-ref --short HEAD`"

git fetch --prune

if git branch | grep " develop$" ;then
    git checkout develop
    git merge --ff origin/develop
fi

if git branch | grep " master$" ;then
    git checkout master
    git merge --ff origin/master
fi

if git branch | grep " main$" ;then
    git checkout main
    git merge --ff origin/main
fi

set +e

git branch -vv \
    | awk '/: gone/{print $1}' \
    | xargs git branch "$delete_cmd"

git checkout "${BRANCH}"
